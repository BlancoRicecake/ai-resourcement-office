# App
APP_ENV=development
APP_DB_PATH=./data/travel_planner.db
PRICE_STALE_MINUTES=15

# LLM (default provider)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Live flights and stays
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Places and routes. Restrict this key by API and server origin in Google Cloud.
GOOGLE_MAPS_API_KEY=

# Optional partner-only adapters (contracts documented; not enabled by default)
BOOKING_API_KEY=
BOOKING_AFFILIATE_ID=
BOOKING_BASE_URL=https://demandapi-sandbox.booking.com/3.2
SKYSCANNER_API_KEY=
SKYSCANNER_BASE_URL=https://partners.api.skyscanner.net
