# No API key is required by this prompt-only bundle.
# 기본 모드는 발행 초안까지만 만들며 키가 필요 없다.
#
# 아래는 사용자가 자동 발행 커넥터를 연결할 때만 채우는 선택 항목이다.
# 실제 값은 사용자의 로컬 환경에만 저장하고, 대화에 붙여넣지 않는다.
# 자세한 발급 방법은 worker/skills/publish-connectors.md 참고.
#
# 블로그/CMS
# WORDPRESS_BASE_URL=
# WORDPRESS_USERNAME=
# WORDPRESS_APP_PASSWORD=
# GHOST_ADMIN_API_URL=
# GHOST_ADMIN_API_KEY=
#
# 뉴스레터
# STIBEE_API_KEY=
# MAILCHIMP_API_KEY=
# CONVERTKIT_API_KEY=
#
# 예약/배포 도구
# BUFFER_ACCESS_TOKEN=
