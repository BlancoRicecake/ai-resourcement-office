# 실제 API 키 파일은 절대 커밋하지 않는다 (.env.example만 커밋)
.env
.env.local
.env.*.local
seed-bundles/*/.env

# 비밀 키 / 인증서 / 자격증명 (실수로도 커밋 금지)
*.pem
*.key
*.pfx
*.p12
*_rsa
*_ed25519
id_rsa*
credentials.json
secrets.json
*.secret
.vercel-oidc-token

# Python
__pycache__/
*.pyc

# Node.js
node_modules/

# 릴리스 산출물 (릴리스 에셋으로만 배포)
dist/

# Vercel 로컬/빌드 산출물
.vercel/
public/

# oh-my-claudecode 로컬 런타임 상태
.omc/

